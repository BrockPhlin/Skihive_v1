.evaluation-page {
  background-color: black;
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  text-align: center;
  width: 80%;
}

.title {
  font-size: 24px;
  color: white;
  margin-bottom: 30px;
}

.evaluation-info {
  margin-bottom: 30px;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 15px;
  margin-bottom: 15px;
  background-color: rgba(34, 34, 34, 0.75);
  border: 1px solid rgba(104, 104, 104, 0.48);
  border-radius: 20px;
}

.info-label {
  font-size: 16px;
  color: #888;
}

.info-value {
  font-size: 16px;
  color: white;
  font-weight: 600;
}

.ai-button {
  padding: 12px 30px;
  background-color: #4CAF50;
  color: white;
  border-radius: 25px;
  border: none;
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 20px;
  width: 100%;
}

.ai-result {
  background-color: rgba(34, 34, 34, 0.75);
  border: 1px solid rgba(104, 104, 104, 0.48);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 20px;
  text-align: left;
}

.result-title {
  font-size: 18px;
  color: #4CAF50;
  font-weight: 600;
  display: block;
  margin-bottom: 10px;
}

.result-scroll {
  max-height: 200px;
}

.result-content {
  font-size: 14px;
  color: white;
  line-height: 1.6;
}

.back-button {
  padding: 12px 30px;
  background-color: #855eee;
  color: white;
  border-radius: 25px;
  border: none;
  font-size: 16px;
  font-weight: 600;
  width: 100%;
}