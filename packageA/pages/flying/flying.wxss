.flying-page {
  background-color: black;
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  text-align: center;
  width: 80%;
}

.title {
  font-size: 24px;
  color: white;
  margin-bottom: 30px;
}

.score-card {
  margin-bottom: 24px;
  padding: 20px 16px;
  border-radius: 16px;
  background: linear-gradient(145deg, rgba(133, 94, 238, 0.25), rgba(40, 40, 40, 0.9));
  border: 1px solid rgba(133, 94, 238, 0.45);
}

.score-label {
  display: block;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 8px;
}

.score-value {
  display: block;
  font-size: 42px;
  font-weight: 700;
  color: #c4b5fd;
  line-height: 1.1;
  margin-bottom: 10px;
}

.score-hint {
  display: block;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.38);
  line-height: 1.4;
  text-align: left;
}

.assembly-info {
  margin-bottom: 24px;
  padding: 16px;
  border-radius: 12px;
  background-color: rgba(133, 94, 238, 0.12);
  border: 1px solid rgba(133, 94, 238, 0.35);
}

.assembly-label {
  display: block;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8px;
}

.assembly-text {
  display: block;
  font-size: 15px;
  color: #e8e0ff;
  line-height: 1.5;
  text-align: left;
}

.flight-status {
  margin-bottom: 30px;
}

.status-text {
  display: block;
  font-size: 20px;
  color: white;
  margin-bottom: 10px;
}

.time-text {
  font-size: 16px;
  color: #888;
}

.controls {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 30px;
}

.control-button {
  padding: 12px 24px;
  border-radius: 25px;
  border: none;
  font-size: 16px;
  font-weight: 600;
}

.control-button.start {
  background-color: #4CAF50;
  color: white;
}

.control-button.stop {
  background-color: #f44336;
  color: white;
}

.control-button[disabled] {
  opacity: 0.5;
}

.nav-button {
  padding: 12px 30px;
  background-color: #855eee;
  color: white;
  border-radius: 25px;
  border: none;
  font-size: 16px;
  font-weight: 600;
}