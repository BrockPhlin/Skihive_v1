/* 装配页面样式：page 必须设高度，否则子节点 height:100% 会塌陷成白屏 */
page {
  height: 100vh;
  background-color: #000000;
}

.assembly-page {
  width: 100%;
  min-height: 100vh;
  height: 100vh;
  background-color: #000000;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* 状态栏占位 */
.status-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 44px;
}

/* 标题区域 */
.title-area {
  position: absolute;
  top: 61.49px;
  left: 27.2px;
  opacity: 1;
}

.main-title {
  font-size: 24px;
  line-height: 33.6px;
  font-family: PingFang SC;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: -1.25%;
}

.subtitle {
  font-size: 10px;
  line-height: 14px;
  font-family: PingFang SC;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: -3%;
  margin-top: 8px;
}

/* 进度显示 */
.progress-area {
  position: absolute;
  top: 77.49px;
  right: 30.14px;
  opacity: 1;
}

.progress-text {
  font-size: 14px;
  line-height: 19.6px;
  font-family: PingFang SC;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  text-align: right;
}

/* 3D预览区域（不拦截点击，避免挡住下方组件按钮） */
.preview-area {
  position: absolute;
  top: 205.22px;
  left: 35.57px;
  width: 321.87px;
  height: 407.19px;
  opacity: 1;
  z-index: 1;
  pointer-events: none;
}

.preview-background {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-background image {
  width: 100%;
  height: 100%;
}

.preview-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 128px;
  height: 128px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.component-icon {
  width: 100%;
  height: 100%;
}

.complete-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.checkmark {
  font-size: 48px;
  color: #FFFFFF;
  margin-bottom: 16px;
}

.complete-text {
  font-size: 24px;
  line-height: 33.6px;
  font-family: PingFang SC;
  font-weight: 600;
  color: #FFFFFF;
}

/* 组件选择区域（必须用独立类名：nth-child 会把 status-bar、标题等也算进去导致错位） */
.component-button {
  position: absolute;
  width: 54.29px;
  height: 54.29px;
  z-index: 10;
  box-sizing: border-box;
}

.component-button image {
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.component-button.is-done {
  border: 2px solid #855eee;
  border-radius: 10px;
  background-color: rgba(133, 94, 238, 0.12);
}

.done-badge {
  position: absolute;
  right: -6px;
  top: -6px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #855eee;
  color: #fff;
  font-size: 11px;
  line-height: 18px;
  text-align: center;
  z-index: 2;
  pointer-events: none;
}

.preview-hint {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
}

/* 螺旋桨 - 左上 */
.component-button--propeller {
  left: 58.57px;
  top: 181.38px;
}

/* 电机 - 右上 */
.component-button--motor {
  left: 280.14px;
  top: 181.38px;
}

/* 电池 - 左下 */
.component-button--battery {
  left: 58.57px;
  top: 543.92px;
}

/* 传感器 - 右下 */
.component-button--sensor {
  left: 280.14px;
  top: 543.92px;
}

/* 机架 - 中上 */
.component-button--frame {
  left: 169px;
  top: 129.9px;
}

/* 相机 - 中下 */
.component-button--camera {
  left: 169.36px;
  top: 593.49px;
}

/* AI分析状态 */
.ai-analysis-area {
  position: absolute;
  left: 30px;
  top: 687px;
  width: 333px;
  height: 39px;
  opacity: 1;
  z-index: 1;
  pointer-events: none;
}

.ai-analysis-area image {
  width: 100%;
  height: 100%;
}

/* 底部按钮 */
.bottom-buttons {
  position: absolute;
  bottom: 35.07px;
  left: 35.07px;
  right: 35.07px;
  display: flex;
  align-items: center;
  gap: 16px;
  opacity: 1;
  z-index: 20;
}

.reset-button {
  width: 50px;
  height: 54.39px;
  border-radius: 8px;
  border: 1px solid #efe4eeff;
  background-color: #0B0B0B;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reset-icon {
  font-size: 24px;
  color: #9D9DA3;
}

.next-button {
  flex: 1;
  height: 55.87px;
  border-radius: 34.35px;
  background-color: #3a3a3a;
  border: 1px solid #2a2a2a;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

/* 未凑齐 6 项：灰色不可点 */
.next-button[disabled] {
  background-color: #3a3a3a !important;
  border-color: #2a2a2a !important;
  opacity: 1;
}

.next-button[disabled] .next-text,
.next-button[disabled] .next-arrow {
  color: rgba(255, 255, 255, 0.28);
}

/* 六项已齐：紫色可点击 */
.next-button.next-button--ready:not([disabled]) {
  background-color: #855eee;
  border-color: #6d4fd4;
}

.next-button.next-button--ready:not([disabled]) .next-text,
.next-button.next-button--ready:not([disabled]) .next-arrow {
  color: #ffffff;
}

.next-text {
  font-size: 16px;
  line-height: 22.4px;
  font-family: PingFang SC;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.35);
}

.next-arrow {
  font-size: 24px;
  color: rgba(255, 255, 255, 0.35);
}

/* 加载动画 */
.loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(255, 255, 255, 0.5);
  border-top: 2px solid transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
