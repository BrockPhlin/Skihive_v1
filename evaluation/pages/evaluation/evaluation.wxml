<view class="evaluation-page">
  <view class="content">
    <text class="title">飞行评估</text>
    
    <view class="evaluation-info">
      <view class="info-item">
        <text class="info-label">飞行时间</text>
        <text class="info-value">{{flightTime}}秒</text>
      </view>
      <view class="info-item">
        <text class="info-label">飞行状态</text>
        <text class="info-value">{{flightStatus}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">评估结果</text>
        <text class="info-value">{{evaluationResult}}</text>
      </view>
    </view>
    
    <button bindtap="handleAIEvaluation" class="ai-button" loading="{{isLoading}}">
      {{isLoading ? 'AI评估中...' : 'AI评估'}}
    </button>
    
    <view class="ai-result" wx:if="{{aiResult}}">
      <text class="result-title">AI评估结果</text>
      <scroll-view scroll-y="true" class="result-scroll">
        <text class="result-content">{{aiResult}}</text>
      </scroll-view>
    </view>
    
    <button bindtap="handleBackToEnvironment" class="back-button">
      返回环境选择
    </button>
  </view>
</view>