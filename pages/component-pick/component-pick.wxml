<view class="pick-page">
  <view class="status-bar"></view>
  <view class="header">
    <text class="header-title">{{pageTitle}}</text>
    <text class="header-sub">{{pageSubtitle}}</text>
  </view>

  <view class="list-wrap">
    <view
      wx:for="{{options}}"
      wx:key="id"
      class="option-item {{selectedId == item.id ? 'selected' : ''}}"
      bindtap="handlePick"
      data-id="{{item.id}}"
    >
      <text class="option-name">{{item.name}}</text>
      <text class="option-meta">重{{item.weight}} · 成本{{item.cost}} · 动力{{item.power}} · 稳{{item.stability}}</text>
    </view>
  </view>

  <button class="confirm-btn" bindtap="handleConfirm">确认选型</button>
</view>
