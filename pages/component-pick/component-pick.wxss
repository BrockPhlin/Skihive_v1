page {
  height: 100vh;
  background-color: #000000;
}

.pick-page {
  min-height: 100vh;
  padding: 0 40rpx 48rpx;
  box-sizing: border-box;
}

.status-bar {
  height: 88rpx;
}

.header {
  margin-bottom: 48rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

.list-wrap {
  margin-bottom: 48rpx;
}

.option-item {
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  background: rgba(34, 34, 34, 0.85);
  border: 2rpx solid rgba(104, 104, 104, 0.5);
}

.option-item.selected {
  border-color: #855eee;
  background: rgba(133, 94, 238, 0.12);
}

.option-name {
  display: block;
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 8rpx;
}

.option-meta {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}

.confirm-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 48rpx;
  background: #855eee;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}
