.login-page {
  background-color: black;
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 100vh;
}

.status-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 44px;
}

.status-bar image {
  width: 100%;
  height: 100%;
}

.background-gradient {
  position: absolute;
  inset: 0;
}

.gradient-circle {
  position: absolute;
  left: calc(115.95 / 393 * 100%);
  top: 201.73px;
  width: calc(159.45 / 393 * 100%);
  height: 159.45px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(133, 94, 238, 0.15) 0%, rgba(133, 94, 238, 0.08) 30%, rgba(133, 94, 238, 0.03) 60%, transparent 100%);
  filter: blur(60px);
}

.gradient-circle.secondary {
  background: radial-gradient(circle, rgba(177, 91, 230, 0.1) 0%, transparent 70%);
  filter: blur(40px);
}

.logo-area {
  position: absolute;
  left: 108.5px;
  top: 111.3px;
  width: 176px;
  height: 50px;
  text-align: center;
  opacity: 1;
  transform: translateY(-20px);
}

.logo-image {
  width: 100%;
  height: 27px;
  display: block;
  margin: 0 auto;
}

.logo-subtitle {
  position: relative;
  left: 0;
  top: 5px;
  width: 100%;
  height: 17px;
  font-size: 12px;
  line-height: 16.8px;
  font-family: 'PingFang SC';
  font-weight: 600;
  background: linear-gradient(180deg, rgba(255, 255, 255, 1) 17%, rgba(199, 188, 227, 1) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 1;
}

.avatar-area {
  position: absolute;
  left: 115.95px;
  top: 181.73px;
  width: 159.45px;
  height: 159.45px;
  opacity: 1;
  transform: scale(0.9);
}

.avatar-area image {
  width: 100%;
  height: 100%;
}

.form-area {
  position: absolute;
  left: 50%;
  top: 58%;
  transform: translate(-50%, -50%); /* 同时居中 X 和 Y */
  width: calc(316.57 / 393 * 100%);
  max-width: 316.57px;
}

.input-field {
  height: 55.54px;
  background-color: rgba(34, 34, 34, 0.75);
  border: 1px solid rgba(104, 104, 104, 0.48);
  border-radius: 58px;
  padding-left: 24px;
  padding-right: 24px;
  font-size: 16px;
  font-family: 'PingFang SC';
  color: #FFFFFF;
}

.input-field:focus {
  border-color: rgb(133, 94, 238);
  background-color: rgba(45, 45, 45, 0.85);
}

.mt-4 {
  margin-top: 16px;
}

.btn {
  padding: 15px;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  border: none;
  width: 100%;
  margin-top: 16px;
}

.btn-primary {
  background-color: #855eee;
  color: white;
}

.btn-secondary {
  background-color: transparent;
  color: #888;
  border: 1px solid #333;
}

.btn-wechat {
  background-color: #07C160;
  color: white;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.wechat-icon {
  font-size: 20px;
}

.loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid white;
  border-top: 2px solid transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.agreement-area {
  position: absolute;
  left: 66.99px;
  top: 790.84px;
  width: 300px;
  height: 16px;
  display: flex;
  align-items: center;
  opacity: 1;
}

.checkbox {
  width: 14px;
  height: 14px;
  border-radius: 2px;
  border: 1px solid rgb(155, 155, 155);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translateY(8px);
}

.checkbox-inner {
  width: 6px;
  height: 6px;
  background-color: white;
}

.agreement-text {
  margin-left: 10px;
  font-size: 12px;
  line-height: 14px;
  vertical-align: middle;
  font-family: 'PingFang SC';
  color: #FFFFFF;
}

.agreement-text text {
  text-decoration: underline;
}