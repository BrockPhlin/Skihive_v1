/* index.wxss */
.index-page {
  background-color: black;
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  text-align: center;
}

.logo-image {
  width: 176px;
  height: 27px;
  display: block;
  margin: 0 auto 10px;
}

.subtitle {
  font-size: 16px;
  color: #888;
  margin-bottom: 40px;
}

.buttons {
  display: flex;
  flex-direction: column;
  gap: 15px;
  width: 200px;
  margin: 0 auto;
}

.btn {
  padding: 15px;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background-color: #855eee;
  color: white;
}

.btn-secondary {
  background-color: transparent;
  color: #888;
  border: 1px solid #333;
}